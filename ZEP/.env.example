# Shared by everyone running this app locally so you all read/write the
# SAME Zep graph. Do not give people separate keys/projects if the goal
# is a shared graph.
ZEP_API_KEY=your_zep_cloud_api_key_here

# Which LLM powers the chat agent's replies. One of: anthropic | openai | gemini
LLM_PROVIDER=anthropic

# API key for the provider selected above. When switching providers, update
# both LLM_PROVIDER and LLM_API_KEY (or pass --provider on the CLI).
LLM_API_KEY=your_llm_api_key_here

# Optional: override the model used per provider.
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o
GEMINI_MODEL=gemini-2.0-flash

# ── Pipecat voice agent ──────────────────────────────────────────────────────
# Stack: Deepgram STT + OpenAI LLM + Cartesia TTS
# Transport: Pipecat SmallWebRTC (free, no third-party account needed)
# Run: python app/voice_agent.py --transport webrtc
# Then open: http://localhost:7860

# Speech-to-text.
DEEPGRAM_API_KEY=your_deepgram_api_key_here
DEEPGRAM_MODEL=nova-3-general
DEEPGRAM_LANGUAGE=en

# Voice LLM. Set to gemini to use Deepgram + Gemini + Cartesia instead.
VOICE_LLM_PROVIDER=openai
VOICE_LLM_TEMPERATURE=0.4
OPENAI_API_KEY=your_openai_api_key_here

# Text-to-speech.
CARTESIA_API_KEY=your_cartesia_api_key_here
CARTESIA_VOICE_ID=your_cartesia_voice_id_here
CARTESIA_MODEL=sonic-3.5
VOICE_LANGUAGE=en
