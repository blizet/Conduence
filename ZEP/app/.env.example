# Shared by everyone running this app locally so you all read/write the
# SAME Zep graph. Do not give people separate keys/projects if the goal
# is a shared graph.
ZEP_API_KEY=your_zep_cloud_api_key_here

# Which LLM powers the chat agent's replies. One of: anthropic | openai | gemini
LLM_PROVIDER=anthropic

# Only the key for the provider you've chosen above is required, but you
# can set all three and switch LLM_PROVIDER (or --provider on the CLI)
# freely without touching anything else.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override the model used per provider.
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o
GEMINI_MODEL=gemini-2.0-flash
