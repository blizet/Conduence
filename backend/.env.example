PORT=4000
FALKORDB_HOST=localhost
FALKORDB_PORT=6380
KAFKA_BROKERS=localhost:19092
# Replay topic on worker start (set 0 in production after initial load)
COT_KAFKA_FROM_BEGINNING=1

# Event-sourced public signal stream
MARKET_SIGNALS_TOPIC=market.signals.public
PUBLISHER_WORKER_GROUP_ID=cot-publisher-worker
SEEKER_WORKER_GROUP_ID=cot-seeker-worker

# CoT seed: per-file decisions (preferred) or batch array
COT_SEED_DECISIONS_DIR=data/decisions
# COT_SEED_DELTAS=data/sample/decisions-batch.json

# Separate end-users
COT_PUBLISHER_USER_ID=user_117
COT_SEEKER_USER_ID=User_902

PUBLISHER_GRAPH_ID=user_117.publisher.v1
SEEKER_GRAPH_ID=user_902.seeker.v1
