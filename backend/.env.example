PORT=4000
FALKORDB_HOST=localhost
FALKORDB_PORT=6380
KAFKA_BROKERS=localhost:19092
# Replay topic on worker start (set 0 in production after initial load)
COT_KAFKA_FROM_BEGINNING=1

# Event-sourced CoT stream + FalkorDB workers
MARKET_SIGNALS_TOPIC=market.signals.public
PUBLISHER_WORKER_GROUP_ID=cot-publisher-worker
SEEKER_WORKER_GROUP_ID=cot-seeker-worker
MAIN_WORKER_GROUP_ID=cot-main-worker

# Graph namespaces (must match playground CoT Builder + Orchestrator nodes + frontend)
COT_PUBLISHER_USER_ID=user_117
COT_SEEKER_USER_ID=User_902
PUBLISHER_GRAPH_ID=user_117.publisher.v1
SEEKER_GRAPH_ID=user_902.seeker.v1
MAIN_USER_NODE_ID=user_771
MAIN_GRAPH_ID=user_771.main.v1

# ── LLM keys (optional backend defaults) ─────────────────────────────────────
# Go Live / Run Workflow prefer API keys on canvas nodes (llmApiKey on sub-agents + orchestrator).
# These env vars are fallbacks for CLI demos and when nodes leave keys empty.
NEWS_LLM_PROVIDER=gemini
NEWS_LLM_API_KEY=
NEWS_LLM_MODEL=gemini-2.0-flash
ARB_LLM_PROVIDER=gemini
ARB_LLM_API_KEY=
ARB_LLM_MODEL=gemini-2.0-flash

# ── Tool provider keys (optional defaults; canvas tool node apiKey takes precedence) ──
COINDESK_API_KEY=
COINMARKETCAP_API_KEY=
CRYPTO_NEWS_API_KEY=
CRYPTOQUANT_API_KEY=
TAVILY_API_KEY=
DEFILLAMA_API_KEY=
COINGECKO_API_KEY=
TELEGRAM_BOT_TOKEN=
X_BEARER_TOKEN=

# ── LangSmith (optional — trace URLs in CoT provenance.execution) ───────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=cot-workflows

# External agent wrapper (HTTP ingest) — agent_id → API key
# JSON: {"sportsScanner.user_demo":"your-secret-key"}
# Or:   sportsScanner.user_demo:your-secret-key
COT_PUBLISHER_KEYS=

# Agentic graph chat (LLM + Supermemory persistence)
SUPERMEMORY_API_KEY=
AGENTIC_LLM_PROVIDER=gemini
AGENTIC_LLM_API_KEY=
AGENTIC_LLM_MODEL=gemini-2.0-flash
# Fallback container when no userSlug is sent from the UI
AGENTIC_CONTAINER_TAG=cot-graph-user

# Correlation context graph for orchestrator (Go Live)
CORRELATION_GRAPH_PATH=data/correlation/correlation_graph.json
COT_WRAPPER_API_KEY=cot-dev-wrapper-key
