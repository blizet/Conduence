{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cot-kb.local/schema/decision-event.schema.json",
  "title": "DecisionEvent",
  "type": "object",
  "required": ["graph_id", "updated_at", "nodes", "edges"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "decision_id": { "type": "string", "minLength": 1 },
    "graph_id": { "type": "string", "minLength": 1 },
    "updated_at": { "type": "string", "format": "date-time" },
    "operation": { "type": "string", "enum": ["assert", "revise", "retract"] },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "raw_sources": { "type": "array", "items": { "type": "string" } },
        "wiki_pages": { "type": "array", "items": { "type": "string" } }
      }
    },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/node" }
    },
    "edges": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/edge" }
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "required": ["node_id", "node_type"],
      "additionalProperties": false,
      "properties": {
        "node_id": { "type": "string", "minLength": 1 },
        "node_type": {
          "type": "string",
          "enum": ["user", "protocol", "market", "trade", "outcome", "feedback", "agent"]
        },
        "properties": { "type": "object" }
      }
    },
    "edge": {
      "type": "object",
      "required": ["source"],
      "additionalProperties": true,
      "properties": {
        "source": { "type": "string" },
        "target": { "type": "string" },
        "targets": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "Action": { "type": "string" },
        "relationship_type": { "type": "string" },
        "direction": { "type": "string", "enum": ["uni-directional", "bi-directional"] },
        "metadata": { "type": "object" }
      },
      "oneOf": [
        { "required": ["target"] },
        { "required": ["targets"] }
      ]
    }
  }
}
